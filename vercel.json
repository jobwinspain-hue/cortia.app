{
  "version": 2,
  "functions": {
    "api/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/salon/:path*", "destination": "/public/index.html" },
    { "source": "/:path*", "destination": "/public/:path*" }
  ]
}
