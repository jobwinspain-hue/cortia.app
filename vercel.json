{
  "version": 2,
  "functions": {
    "api/*.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "^/logo/(.*)", "dest": "/logo/$1" },
    { "src": "^/salon/?$", "dest": "/api/landing" },
    { "src": "^/salon/(.*)", "dest": "/index.html" },
    { "src": "^/$", "dest": "/api/landing" },
    { "src": ".*", "dest": "/api/landing" }
  ]
}
